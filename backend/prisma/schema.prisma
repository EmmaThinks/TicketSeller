generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENTE
  ADMIN
}

enum TicketStatus {
  DISPONIBLE
  RESERVADO
  VENDIDO
}

model User {
  id         String    @id @default(uuid())
  nombre     String
  email      String    @unique
  password   String
  rol        Role      @default(CLIENTE)
  fotoPerfil String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ordenes    Order[]
}

model Concert {
  id            String   @id @default(uuid())
  titulo        String
  banda       String   @default("Por definir")
  descripcion String   @default("Sin descripción")
  fotoConcierto String?
  fecha         DateTime
  lugar         String
  capacidad     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tickets       Ticket[]
}

model Order {
  id           String   @id @default(uuid())
  total        Decimal
  fecha_compra DateTime @default(now())

  usuarioId    String
  usuario      User     @relation(fields: [usuarioId], references: [id])

  tickets      Ticket[]
}

model Ticket {
  id           String       @id @default(uuid())
  precio       Decimal
  estado       TicketStatus @default(DISPONIBLE)

  conciertoId  String
  concierto    Concert      @relation(fields: [conciertoId], references: [id])

  orderId      String?
  orden        Order?       @relation(fields: [orderId], references: [id])
}
